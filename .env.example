# Spotify integration for /fun
# 1. Create app: https://developer.spotify.com/dashboard
# 2. Add redirect URI: http://127.0.0.1:8888/callback
# 3. Copy credentials below
# 4. Run: npm run spotify:token
# 5. Paste the printed SPOTIFY_REFRESH_TOKEN below + into Vercel env vars
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
